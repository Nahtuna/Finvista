# ==============================================================================
# 🏆 FINVISTA QUANT PRO - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' and fill in your private credentials.
# DO NOT COMMIT THE REAL '.env' FILE TO GIT!
# ==============================================================================

# --- DATABASE CONFIGURATION ---
# Default SQLite connection URL. Can be changed to PostgreSQL/MySQL in production.
DATABASE_URL=sqlite:///data/finvista.db

# --- SECURITY & AUTHENTICATION ---
# Generate a strong key in production (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=finvista_saas_ultra_secure_secret_key_default_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- TELEGRAM BOT WEBHOOK ALERTS ---
# Credentials for active market scan alerts to Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE
TELEGRAM_ALERTS_ENABLED=true
